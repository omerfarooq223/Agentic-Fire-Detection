# FireWatch AI — Environment Configuration

# Computer Vision Model Path
# If you don't have best.pt, the system will fallback to a heuristic detector or segmentation model.
FIRE_DETECT_MODEL=./best.pt

# API Keys
# Required for RAG Assistant answer synthesis
GROQ_API_KEY=your_groq_api_key_here

# Backend Configuration
BACKEND_URL=http://localhost:8000
VITE_BACKEND_URL=http://localhost:8000
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Emergency Alert Configuration
# Safe default: demo mode records prepared alerts without contacting real people.
# For live email: set AUTO_ALERTS_ENABLED=true and ALERT_MODE=email.
# For live email + voice: set AUTO_ALERTS_ENABLED=true and ALERT_MODE=email_and_call.
ALERT_MODE=demo
AUTO_ALERTS_ENABLED=false
ALERT_CONFIRMATION_FRAMES=3
ALERT_COOLDOWN_SECONDS=300

# The sender email used for the Gmail API (OAuth2)
REMINDER_EMAIL_SENDER=your_email@gmail.com
# Comma-separated list of recipient emails
REMINDER_EMAIL_RECEIVERS=stakeholder1@email.com,stakeholder2@email.com

# Optional Twilio Voice Configuration.
# Twilio trial access can be region/account limited. Leave these blank for demo mode.
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
EMERGENCY_RECIPIENT_PHONE=+1987654321
