# ============================================================
# Fire & Smoke Detection — .gitignore
# ============================================================

# Sensitive Credentials
.env
credentials.json
token.json

# Databases and Local Storage
fire_system.db
detection_images/
fire_seg_final_results.zip
*.pt

# Python/Environment
__pycache__/
.venv/
.env.local
.DS_Store

# Python virtual environment
venv/
env/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Model weights (large files — use Git LFS or store separately)
*.pt
*.pth
*.onnx

# Database files (contain runtime data)
*.db
*.sqlite

# macOS metadata
.DS_Store
.AppleDouble
.LSOverride

# Zip archives (commit originals only if needed via LFS)
*.zip

# IDE / editor
.vscode/
.idea/
*.swp

# Media & Archives
*.mp4
*.avi
_archive/
local_backup/
New Folder With Items/

# Output directories
detection_images/*
!detection_images/.gitkeep
rag_documents/documents.json
