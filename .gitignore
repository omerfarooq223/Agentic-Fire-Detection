# ============================================================
# Fire & Smoke Detection — .gitignore
# ============================================================

# Secrets — never commit API keys
.env

# Python virtual environment
.venv/
venv/
env/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Model weights (large files — use Git LFS or store separately)
*.pt
*.pth
*.onnx

# Database files (contain runtime data)
*.db
*.sqlite

# macOS metadata
.DS_Store
.AppleDouble
.LSOverride

# Zip archives (commit originals only if needed via LFS)
*.zip

# IDE / editor
.vscode/
.idea/
*.swp

# Media & Archives
*.mp4
*.avi
_archive/

# Output directories
detection_images/*
!detection_images/.gitkeep
rag_documents/documents.json
